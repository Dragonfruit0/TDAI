# GEMINI_API_KEY: Required for generating design variants, suggestions, and carrying out chat conversations.
# This is loaded at build time and injected via the Vite configuration setup.
GEMINI_API_KEY="AI_STUDIO_OR_GEMINI_KEY"

# VITE_STRIPE_PUBLISHABLE_KEY: Your Stripe Publishable Key.
# Used on the client-side to authorize secure transaction tunnels with Stripe.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_stripe_publishable_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
